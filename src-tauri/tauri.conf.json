{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DebridDownloader",
  "version": "1.1.3",
  "identifier": "com.jonathan.debriddownloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DebridDownloader",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Jonathan Vargas (53MUTM55LC)",
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["magnet"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5REMxQkFEN0U2RTk3QjUKUldTMWwyNStyUnZjNlY4SU5PL0lpdHpSL21JZ2hiNGEzNklhMGhFaHhzaTJqb0lQQnUxNk1CQmUK",
      "endpoints": [
        "https://github.com/CasaVargas/DebridDownloader/releases/latest/download/latest.json"
      ]
    }
  }
}
